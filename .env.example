# ---- Application configuration ----
# Copy this file to `.env.local` and adjust as needed.

# Runtime environment: development | test | production
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/food-ordering-db

# Secret used to sign JWTs. MUST be a strong random value in production.
JWT_SECRET=change-this-to-a-long-random-string

# JWT lifetime (zeit/ms format, e.g. 7d, 12h, 30m)
JWT_EXPIRES_IN=7d

# bcrypt cost factor (4-15). Higher = slower but stronger.
BCRYPT_ROUNDS=10

# Login throttling: max attempts per window and window length (seconds)
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SEC=60
